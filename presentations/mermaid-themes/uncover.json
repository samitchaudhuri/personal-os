{
  "theme": "base",
  "htmlLabels": true,
  "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, Segoe UI, Helvetica, Arial, sans-serif",
  "themeVariables": {
    "darkMode": true,
    "background": "#00000000",

    "primaryColor": "#585858",
    "primaryBorderColor": "#8b8b8b",
    "primaryTextColor": "#f5f5f5",

    "secondaryColor": "#4a4a4a",
    "secondaryBorderColor": "#7d7d7d",
    "secondaryTextColor": "#f5f5f5",

    "tertiaryColor": "#3a3a3a",
    "tertiaryBorderColor": "#6e6e6e",
    "tertiaryTextColor": "#f5f5f5",

    "lineColor": "#f5f5f5",
    "textColor": "#f5f5f5",
    "mainBkg": "#585858",

    "clusterPadding": 0,
    "clusterBkg": "#3a3a3a",
    "clusterBorder": "#6e6e6e",
    "defaultLinkColor": "#f5f5f5",
    "edgeLabelBackground": "#00000000",
    "nodeTextColor": "#f5f5f5"
  },
  "flowchart": {
    "nodeSpacing": 0,
    "rankSpacing": 0,
    "useMaxWidth": true
  }
}
