# Personal OS .gitignore
# Workspace root for AI-powered productivity system

# Repositories for code projects 
project_repos/*              
!project_repos/.gitkeep
!project_repos/README.md

# Personal task files
Tasks/*.md
!Tasks/.gitkeep
!Tasks/README.md
BACKLOG.md

# Personal knowledge files
Knowledge/*.md
!Knowledge/.gitkeep
!Knowledge/README.md

# Personal configuration
CLAUDE.md       # If customized from template
GOALS.md        # Personal goals

# Keep templates and examples
!CLAUDE_TEMPLATE.md
!config.example.yaml
!Tasks/example.md
!CRM/example.md

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/
.env

# Presentations build artifacts
presentations/build/
*.generated.md

# IDE & Editor configs
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/extensions.json

# Optional: if you ever create local-only overrides
.vscode/settings.local.json

.cursor/*
!.cursor/rules/

# If rules should also be selective:
# !.cursor/rules/*.mdc

.idea/
.obsidian/
*.swp
*.swo
*~
.DS_Store

# Tool-specific
.specstory/
.factory/
.claude/settings.local.json
.claude/agents
.agent

# Logs
*.log
logs/

# Testing
test_*.py
*.test.py
.pytest_cache/
.coverage

# MCP/System
.mcp_cache/
*.pid
*.lock
node_modules
